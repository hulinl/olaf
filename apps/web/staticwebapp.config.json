{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "_doc": [
    "HTML must NEVER be cached aggressively — that's how a deployed iPhone",
    "PWA ends up showing month-old code even after pull-to-refresh. We",
    "force HTML revalidation on every request (etag still skips full",
    "download when the body is unchanged) and tell the version-check",
    "endpoint to skip all caches.",
    "",
    "Next.js hashed asset URLs (e.g. /_next/static/chunks/abc.def.js) are",
    "safe to cache forever — the URL itself changes when the content does."
  ],
  "routes": [
    {
      "route": "/version.json",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache"
      }
    },
    {
      "route": "/",
      "headers": {
        "Cache-Control": "no-cache, must-revalidate"
      }
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "no-cache, must-revalidate"
      }
    },
    {
      "route": "/_next/static/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/icon.svg",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/apple-icon.png",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    }
  ]
}
