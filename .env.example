# Django
DJANGO_SECRET_KEY=dev-secret-key-change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api

# Database
DATABASE_URL=postgres://olaf:olaf@postgres:5432/olaf

# Redis (Celery broker + cache)
REDIS_URL=redis://redis:6379/0

# Email (MailHog locally; ACS Email in production)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=no-reply@olaf.events

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000
FRONTEND_URL=http://localhost:3000

# Web Push (VAPID). Generate a keypair per environment:
#   docker compose exec api python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); print(v.private_pem().decode())"
# Empty values disable Web Push entirely (subscribe endpoint returns 503).
VAPID_SUBJECT=mailto:no-reply@olaf.events
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
